{
  "name": "eko-studio",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "next dev",
    "dev:electron": "concurrently -n next,electron \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "next build",
    "build:electron": "pnpm build && tsc -p tsconfig.electron.json",
    "build:electron:mac": "pnpm build:electron && node scripts/copy-playwright-browsers.js darwin && electron-builder --mac",
    "build:electron:mac:fast": "pnpm build:electron && node scripts/copy-playwright-browsers.js darwin && electron-builder --mac --arm64 -c.compression=store -c.mac.target=dir",
    "build:electron:win": "pnpm build:electron && node scripts/copy-playwright-browsers.js win32 && electron-builder --win",
    "build:electron:linux": "pnpm build:electron && node scripts/copy-playwright-browsers.js linux && electron-builder --linux",
    "build:electron:all": "pnpm build:electron && node scripts/copy-playwright-browsers.js && electron-builder --mac --win --linux",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx src/agent/agent-e2e.ts",
    "init": "pnpm playwright install chromium",
    "agent:test": "tsx watch --clear-screen=false ./src/agent/agent-test.ts",
    "deploy": "vercel deploy --prod",
    "postinstall:electron": "electron-builder install-app-deps",
    "postinstall:web": "pnpm install --force"
  },
  "dependencies": {
    "@eko-ai/eko": "4.1.3",
    "@eko-ai/eko-nodejs": "4.1.3",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@rive-app/react-webgl2": "^4.29.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@xyflow/react": "^12.11.0",
    "ai": "^6.0.204",
    "ansi-to-react": "^6.2.6",
    "canvas": "^3.2.0",
    "chromium-bidi": "^12.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.6.2",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.18.0",
    "merge-deep": "^3.0.3",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "playwright": "^1.57.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "radix-ui": "^1.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.80.0",
    "react-jsx-parser": "^2.4.1",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.6.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
